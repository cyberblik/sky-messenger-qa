      "name": "SRCH-01 Поиск пользователей по части ника",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Ответ является массивом\", function () {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Найден хотя бы один пользователь\", function () {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.length).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
